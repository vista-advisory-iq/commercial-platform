# Copy to .env and fill in. Never commit .env.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection
DB_NAME=vap_commercial
DB_USER=vap_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Stage 1: how a CONDITIONAL gate (with no FAIL) affects the outcome.
#   ADVANCE_CAPPED (default) | BLOCK | PASS   (a FAIL always declines)
STAGE1_CONDITIONAL_POLICY=ADVANCE_CAPPED

# Stage 2: GO / CONDITIONAL / NO-GO bands on the weighted total (0-100).
# DEL-confirmed: >=80 GO, 65-79 CONDITIONAL, <65 NO-GO. Set to "" to disable verdicts.
STAGE2_SCORE_BANDS={"GO": 80, "CONDITIONAL": 65}

# Email. Dev prints to the console; set real SMTP (host/port/user/password/TLS) for production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@vap.local
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
